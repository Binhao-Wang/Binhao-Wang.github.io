---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/site";
---

<BaseLayout
  title="Contact"
  description="Contact Binhao Wang for research conversations on rock rheology, earthquake-cycle dynamics, and observational seismology."
>
  <section class="site-shell contact-intro">
    <div>
      <p class="page-kicker">Contact</p>
      <h1 class="page-title">Start with the scientific question.</h1>
      <p class="page-dek">
        I welcome research conversations on rock rheology, earthquake cycles, friction experiments, dynamic rupture, and observational seismology.
      </p>
      <div class="contact-actions">
        <a class="button button-ink" href={"mailto:" + profile.email}>Email Binhao</a>
        <a class="button button-outline" href="/files/Binhao_Wang_CV.pdf">Download CV</a>
      </div>
    </div>

    <aside class="contact-card">
      <p class="section-kicker">Direct contact</p>
      <a href={"mailto:" + profile.email}>{profile.email}</a>
      <p>{profile.affiliation}</p>
    </aside>
  </section>

  <section class="section-tight">
    <div class="site-shell contact-detail-grid">
      <article>
        <span class="contact-index">01</span>
        <h2>Academic home</h2>
        <p>{profile.affiliation}</p>
      </article>
      <article>
        <span class="contact-index">02</span>
        <h2>Research identity</h2>
        <a class="text-link" href={profile.links.orcid} rel="me external">ORCID record</a>
      </article>
      <article>
        <span class="contact-index">03</span>
        <h2>Code and projects</h2>
        <a class="text-link" href={profile.links.github} rel="external">GitHub profile</a>
      </article>
    </div>
  </section>
</BaseLayout>
