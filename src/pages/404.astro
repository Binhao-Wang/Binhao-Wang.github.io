---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <section class="site-shell page-hero">
    <div>
      <p class="page-kicker">404</p>
      <h1 class="page-title">This fault trace ends here.</h1>
      <p class="page-dek">The page you requested is not part of this site. Return to the research overview to find the current record.</p>
      <div class="page-actions">
        <a class="button button-ink" href="/">Go home</a>
        <a class="button button-outline" href="/research">Research</a>
      </div>
    </div>
  </section>
</BaseLayout>
